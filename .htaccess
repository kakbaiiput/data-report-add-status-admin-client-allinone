Options -Indexes
RewriteEngine On

# Semua request ke root → index.php
RewriteRule ^$ index.php [L]

# Request dengan ?p= token → router.php
RewriteCond %{QUERY_STRING} ^p=([a-f0-9]+)$
RewriteRule ^$ router.php [L,QSA]

# Blokir akses langsung ke file .html (kecuali dari localhost/internal)
RewriteCond %{REQUEST_FILENAME} \.html$
RewriteRule ^(.+)\.html$ / [R=302,L]

# Blokir akses langsung ke router.php dan index.php via URL
RewriteRule ^(router|index)\.php$ / [R=302,L]

# Arahkan semua request lain ke index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L]
